# ── AI Backend ────────────────────────────────────────────────────────────────
#
# Option A — Local Ollama (no internet required after model download)
#   Install Ollama: https://ollama.com
#   Pull the model: ollama pull gemma4:e4b
#
OLLAMA_BASE_URL=http://localhost:11434
GEMMA_MODEL=gemma4:e4b

# Option B — Google AI Studio API (no GPU / no Ollama needed)
#   Get a free key: https://aistudio.google.com → Get API key
#   Uncomment the line below and paste your key:
#
# GOOGLE_API_KEY=your_key_here
#
#   Setting GOOGLE_API_KEY automatically switches the app to Google's Gemma API.
#   No other changes needed — the Settings page will reflect this automatically.

# Option C — Auto (default)
#   Leave both blank. The app tries Ollama first; if unreachable it falls back
#   to Google AI if GOOGLE_API_KEY is set. If neither is available, the demo
#   data still loads and the UI works — only the Analyze button needs a backend.

# ── Demo Configuration ────────────────────────────────────────────────────────
DEMO_CITY=lagos
DEMO_CENTER_LAT=6.4541
DEMO_CENTER_LNG=3.4218
